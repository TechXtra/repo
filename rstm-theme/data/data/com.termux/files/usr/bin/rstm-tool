#!/bin/bash
clear
echo -e "\e[1;33m--- @RstmMod MODDING TOOLS ---\e[0m"
echo "1) Clean Junk (Cache)"
echo "2) Device Specs (Neofetch)"
echo "3) Exit"
read -p "Option: " t_opt
case $t_opt in
 1) rm -rf ~/.cache/* && echo "Cleaned!" ;;
 2) neofetch || pkg install neofetch -y && neofetch ;;
 *) exit ;;
esac
