#!/bin/bash
# @RstmMod Advanced Font & Size Manager
FONT_DIR="/data/data/com.termux/files/usr/share/rstm-mod/fonts"
TERMUX_DIR="$HOME/.termux"

clear
echo "==============================="
echo "   @RstmMod FONT MANAGER Pro   "
echo "==============================="
echo "1) Change Font Style (20+ Options)"
echo "2) Adjust Font Size"
echo "3) Exit"
read -p "Select option [1-3]: " main_opt

if [ "$main_opt" == "1" ]; then
    fonts=($(ls $FONT_DIR))
    echo -e "\nAvailable Coding Fonts:"
    for i in "${!fonts[@]}"; do
        echo "$((i+1))) ${fonts[$i]}"
    done
    read -p "Choose font number: " f_num
    selected_font=${fonts[$((f_num-1))]}
    
    if [ -z "$selected_font" ]; then
        echo "Invalid selection!"
        exit 1
    fi
    
    mkdir -p $TERMUX_DIR
    cp "$FONT_DIR/$selected_font" "$TERMUX_DIR/font.ttf"
    termux-reload-settings
    echo -e "\n✅ Applied: $selected_font"

elif [ "$main_opt" == "2" ]; then
    read -p "Enter font size (e.g., 12, 14, 16): " f_size
    touch $TERMUX_DIR/termux.properties
    sed -i '/font-size/d' $TERMUX_DIR/termux.properties
    echo "font-size = $f_size" >> $TERMUX_DIR/termux.properties
    termux-reload-settings
    echo -e "\n✅ Font size updated to $f_size!"
else
    echo "Exiting..."
fi
