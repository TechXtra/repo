#!/bin/bash

# Colors
CYAN='\e[1;36m'
GREEN='\e[1;32m'
ORANGE='\e[1;33m'
BLUE='\e[1;34m'
NC='\e[0m' # No Color

clear
echo -e "${CYAN}@RstmMod-Theme Installer v2.5${NC}"
echo -e "${GREEN}Professional terminal customization for Termux${NC}\n"

echo -e "${ORANGE}[*] Checking system dependencies...${NC}"
sleep 0.5

# Function for checklist effect
check_step() {
    echo -e "${ORANGE}[/] $1 installed${NC}"
    sleep 0.4
}

check_step "fish"
check_step "git"
check_step "termux-api"
check_step "rstm-font-engine"

echo -e "${GREEN}[+] All dependencies are installed${NC}"
sleep 0.5

echo -e "${ORANGE}[*] Finalizing theme configuration...${NC}"
mkdir -p ~/.termux
cp /data/data/com.termux/files/usr/share/rstm-mod/fonts/JetBrains.ttf ~/.termux/font.ttf
termux-reload-settings
sleep 1

# --- USER INPUT SECTION (As per your screenshot) ---
echo -ne "${BLUE}Enter your name for prompt (blank for @RstmMod): ${NC}"
read user_name

if [ -z "$user_name" ]; then
    user_name="RstmMod"
fi

# Update fish config with the custom name
FISH_CONF="$HOME/.config/fish/config.fish"
if [ -f "$FISH_CONF" ]; then
    sed -i "s/(@RstmMod)/(@$user_name)/g" "$FISH_CONF"
fi

echo -e "\n${GREEN}[+] Setup Complete! Restart Termux Boss.${NC}"

