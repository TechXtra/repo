#!/bin/bash

# Colors (Exact Match)
CYAN='\e[1;36m'
GREEN='\e[1;32m'
ORANGE='\e[1;33m'
BLUE='\e[1;34m'
NC='\e[0m'

clear

# --- @RstmMod ASCII Banner Start ---
echo -e "${CYAN}"
echo "  _____       _             __  __           _ "
echo " |  __ \     | |           |  \/  |         | |"
echo " | |__) |___ | |_ _ __ ___ | \  / | ___   __| |"
echo " |  _  // __|| __| '_ ' _ \| |\/| |/ _ \ / _' |"
echo " | | \ \\__ \| |_| | | | | | |  | | (_) | (_| |"
echo " |_|  \_\___/ \__|_| |_| |_|_|  |_|\___/ \__,_|"
echo -e "${NC}"
# --- ASCII Banner End ---

# Line 1 & 2
echo -e "${CYAN}@RstmMod-Theme Installer v3.2${NC}"
echo -e "${GREEN}Professional terminal customization for Termux${NC}\n"

# Line 4: Checking Dependencies
echo -e "${ORANGE}[*] Checking system dependencies...${NC}"
sleep 0.5

# Lines 5 to 9: Specific Tools Checklist
echo -e "${GREEN}[/] fish installed${NC}" ; sleep 0.3
echo -e "${GREEN}[/] starship installed${NC}" ; sleep 0.3
echo -e "${GREEN}[/] git installed${NC}" ; sleep 0.3
echo -e "${GREEN}[/] jp2a installed${NC}" ; sleep 0.3
echo -e "${GREEN}[/] eza installed${NC}" ; sleep 0.3

# Line 10: Success Message
echo -e "${GREEN}[+] All dependencies are installed${NC}"
sleep 0.5

# Line 11: Downloading Message
echo -e "${ORANGE}[*] Downloading theme repository to temp directory...${NC}"
sleep 1.5

# Line 12: Input Prompt
echo -ne "${CYAN}Enter your name for prompt (blank for default): ${NC}"
read user_name

# Default name logic
if [ -z "$user_name" ]; then
    user_name="RstmMod"
fi

# Apply custom name to config.fish
FISH_CONF="$HOME/.config/fish/config.fish"
if [ -f "$FISH_CONF" ]; then
    # Ye line (@RstmMod) ko dhoond kar user ke naam se replace karegi
    sed -i "s/(@RstmMod)/(@$user_name)/g" "$FISH_CONF"
fi

# Final setup tasks
mkdir -p ~/.termux
cp /data/data/com.termux/files/usr/share/rstm-mod/fonts/JetBrains.ttf ~/.termux/font.ttf
termux-reload-settings

echo -e "\n${GREEN}[+] Setup Complete! Restart Termux Boss.${NC}"

