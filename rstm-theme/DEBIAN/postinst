#!/bin/bash

# Colors
CYAN='\e[1;36m'
GREEN='\e[1;32m'
ORANGE='\e[1;33m'
BLUE='\e[1;34m'
NC='\e[0m'

clear

# --- @RstmMod ASCII Banner ---
echo -e "${CYAN}"
echo "  _____       _             __  __           _ "
echo " |  __ \     | |           |  \/  |         | |"
echo " | |__) |___ | |_ _ __ ___ | \  / | ___   __| |"
echo " |  _  // __|| __| '_ ' _ \| |\/| |/ _ \ / _' |"
echo " | | \ \\__ \| |_| | | | | | |  | | (_) | (_| |"
echo " |_|  \_\___/ \__|_| |_| |_|_|  |_|\___/ \__,_|"
echo -e "${NC}"

# --- Telegram Channel ---
echo -e "${BLUE}  📢 Join Telegram: ${CYAN}https://t.me/RstmMod${NC}"
echo -e "${BLUE}  -------------------------------------------${NC}\n"

# --- Version Text (Ab ye v3.5 dikhayega) ---
echo -e "${CYAN}@RstmMod-Theme Installer v3.5${NC}"
echo -e "${GREEN}Professional terminal customization for Termux${NC}\n"

# ... baaki ka checklist code ...
echo -e "${ORANGE}[*] Checking system dependencies...${NC}"
sleep 0.5
echo -e "${GREEN}[/] fish installed${NC}" ; sleep 0.2
echo -e "${GREEN}[/] starship installed${NC}" ; sleep 0.2
echo -e "${GREEN}[/] git installed${NC}" ; sleep 0.2
echo -e "${GREEN}[/] jp2a installed${NC}" ; sleep 0.2
echo -e "${GREEN}[/] eza installed${NC}" ; sleep 0.2
echo -e "${GREEN}[+] All dependencies are installed${NC}"
sleep 0.5
echo -e "${ORANGE}[*] Downloading theme repository to temp directory...${NC}"
sleep 1

# Input Prompt
echo -ne "${CYAN}Enter your name for prompt (blank for default): ${NC}"
read user_name
[ -z "$user_name" ] && user_name="RstmMod"

# Config update
FISH_CONF="$HOME/.config/fish/config.fish"
[ -f "$FISH_CONF" ] && sed -i "s/(@.*)/(@$user_name)/g" "$FISH_CONF"

# Final tasks
mkdir -p ~/.termux
cp /data/data/com.termux/files/usr/share/rstm-mod/fonts/JetBrains.ttf ~/.termux/font.ttf
termux-reload-settings

echo -e "\n${GREEN}[+] Setup Complete! Restart Termux Boss.${NC}"
